  "keyFeatures": [
    "Job deduplication with configurable result caching",
    "Request/response pattern with enqueueAndWait",
    "Multiple storage backends: Redis/Valkey, filesystem, in-memory",
    "Automatic retries with exponential backoff",
    "Stalled job recovery with Reaper",
    "Graceful shutdown with in-flight job completion",
    "TypeScript native with full type safety",
    "Leader election for high availability"
  ],
  "publicApiSurface": [
    "Queue",
    "Reaper",
    "MemoryStorage",
